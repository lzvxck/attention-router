{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/block-dangerous.sh",
            "commandWindows": "pwsh -NonInteractive -File .codex/hooks/block-dangerous.ps1"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/block-env-patch.sh",
            "commandWindows": "pwsh -NonInteractive -File .codex/hooks/block-env-patch.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/format-and-typecheck.sh",
            "commandWindows": "pwsh -NonInteractive -File .codex/hooks/format-and-typecheck.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/verify-gate.sh",
            "commandWindows": "pwsh -NonInteractive -File .codex/hooks/verify-gate.ps1"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/log-trajectory.sh",
            "commandWindows": "pwsh -NonInteractive -File .codex/hooks/log-trajectory.ps1"
          }
        ]
      }
    ]
  }
}
